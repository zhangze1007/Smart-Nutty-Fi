GEMINI_API_KEY=

# Optional server hint for local Firebase Admin usage.
FIREBASE_PROJECT_ID=

# Optional frontend Firestore config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional risk configuration overrides.
# Default profile: conservative | balanced | flexible
RISK_DEFAULT_PROFILE=balanced
RISK_HIGH_RISK_KEYWORDS=crypto,exchange,wallet
RISK_UNKNOWN_PAYEE_REQUIRES_REVIEW=true

RISK_PROFILE_CONSERVATIVE_MAX_TRANSFER_WITHOUT_CONFIRM=500
RISK_PROFILE_CONSERVATIVE_MIN_BALANCE_THRESHOLD=800

RISK_PROFILE_BALANCED_MAX_TRANSFER_WITHOUT_CONFIRM=1000
RISK_PROFILE_BALANCED_MIN_BALANCE_THRESHOLD=500

RISK_PROFILE_FLEXIBLE_MAX_TRANSFER_WITHOUT_CONFIRM=2000
RISK_PROFILE_FLEXIBLE_MIN_BALANCE_THRESHOLD=250

# Production note:
# - keep GEMINI_API_KEY in Secret Manager
# - prefer Firestore document appConfig/risk for remote overrides
# - avoid committing real secrets to this file
